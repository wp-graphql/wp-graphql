{
	"allowedPrefixes": [
		"graphql_"
	],
	"legacyAllowedPrefixes": [
		"pre_graphql_",
		"register_graphql_"
	],
	"deprecatedPrefixes": [
		"wpgraphql_",
		"wp_graphql_",
		"init_graphql_"
	],
	"allowedHookNamePattern": "^[a-z0-9_]+$",
	"minSegmentsAfterPrefix": 2,
	"dynamicNamePattern": "^[\"']?graphql_",
	"coreHookAllowlist": [
		"query_vars",
		"request",
		"wp_enqueue_scripts",
		"all_plugins",
		"show_network_active_plugins",
		"retrieve_password_title",
		"retrieve_password_message",
		"get_the_excerpt",
		"the_excerpt"
	]
}
